indicator("✅ ARAL ÖMER ARSLAN - DİNAMİK KANAL V2 ✅", overlay=true, max_labels_count=500, max_lines_count=500, max_bars_back=1000)

// --- 1. AYARLAR ---
groupInput     = input.string("ÖMER", "Hisse Grubu Seç", options=["XYLDZ 1", "XYLDZ 2", "XYLDZ 3", "XYLDZ 4", "XYLDZ 5", "XYLDZ 6", "XYLDZ 7", "ANA 1", "ANA 2", "ANA 3", "ANA 4", "ÖMER"])
fibo_lookback  = input.int(400, "Geriye Bakış (Fibo & VWAP)", minval=50)
radar_lookback = input.int(3, "Radar Mum Tarama Sayısı", minval=1, maxval=100)
offset_x       = input.int(25, "Radar Sağa Uzaklık")

// Dinamik Mum Kanalı Ayarları
show_candle_channel = input.bool(true, "Dinamik Mum Kanalını Göster", group="Yeni Özellik: Mum Kanalı")
channel_color       = input.color(color.new(#9c27b0, 85), "Aktif Kanal Dolgu", group="Yeni Özellik: Mum Kanalı")
channel_border_color= input.color(color.new(#9c27b0, 40), "Aktif Kanal Çerçeve/Fiyat", group="Yeni Özellik: Mum Kanalı")
upper_pred_color    = input.color(color.new(color.red, 70), "Üst Öngörü Kanal Rengi", group="Yeni Özellik: Mum Kanalı")
lower_pred_color    = input.color(color.new(color.green, 70), "Alt Öngörü Kanal Rengi", group="Yeni Özellik: Mum Kanalı")

// Öngörü Yazı Renkleri
upper_txt_color     = input.color(color.red, "Üst Öngörü Yazı Rengi", group="Yeni Özellik: Mum Kanalı")
lower_txt_color     = input.color(color.green, "Alt Öngörü Yazı Rengi", group="Yeni Özellik: Mum Kanalı")

// Destek Direnç Ayarları
pp_period      = input.int(20, "D&D Hassasiyeti (Pivot)", minval=5, group="Destek & Direnç")
show_labels    = input.bool(true, "Fiyat Etiketlerini Göster", group="Destek & Direnç")
tp_min_dist    = input.float(1.5, "Hedefler Arası Min Mesafe (%)", minval=0.1, step=0.1, group="Destek & Direnç") / 100 + 1

// Wave Trend Girdileri
n1 = input.int(10, "WT Kanal Periyodu", group="Wave Trend Ayarları")
n2 = input.int(21, "WT Ortalama Periyodu", group="Wave Trend Ayarları")
obLevel = input.float(60, "Aşırı Alım Eşiği", group="Wave Trend Ayarları")
osLevel = input.float(-60, "Aşırı Satım Eşiği", group="Wave Trend Ayarları")

// MACD Girdileri
fast_length = input.int(12, "MACD Hızlı", group="MACD Ayarları")
slow_length = input.int(26, "MACD Yavaş", group="MACD Ayarları")
signal_smoothing = input.int(9, "MACD Sinyal", group="MACD Ayarları")

// Görünüm Ayarları
arrow_dist_input = input.float(2.5, "Okların Uzaklığı (%)", step=0.5, group="Görünüm") 
text_dist_input  = input.float(0.5, "Yazıların Uzaklığı (%)", step=0.1, group="Görünüm")

// --- TABLO AYARLARI ---
t_note_1 = input.string("5M", "5M Notu", group="Tablo 5M Ayarları"), t_bg_1 = input.color(color.new(color.orange, 0), "5M Arka Plan", group="Tablo 5M Ayarları"), t_txt_1 = input.color(color.white, "5M Yazı Rengi", group="Tablo 5M Ayarları")
t_note_2 = input.string("15M", "15M Notu", group="Tablo 15M Ayarları"), t_bg_2 = input.color(color.new(color.orange, 0), "15M Arka Plan", group="Tablo 15M Ayarları"), t_txt_2 = input.color(color.white, "15M Yazı Rengi", group="Tablo 15M Ayarları")
t_note_3 = input.string("1H", "1H Notu", group="Tablo 1H Ayarları"), t_bg_3 = input.color(color.new(color.orange, 0), "1H Arka Plan", group="Tablo 1H Ayarları"), t_txt_3 = input.color(color.white, "1H Yazı Rengi", group="Tablo 1H Ayarları")
t_note_4 = input.string("2H", "2H Notu", group="Tablo 2H Ayarları"), t_bg_4 = input.color(color.new(color.orange, 0), "2H Arka Plan", group="Tablo 2H Ayarları"), t_txt_4 = input.color(color.white, "2H Yazı Rengi", group="Tablo 2H Ayarları")
t_note_5 = input.string("4H", "4H Notu", group="Tablo 4H Ayarları"), t_bg_5 = input.color(color.new(color.orange, 0), "4H Arka Plan", group="Tablo 4H Ayarları"), t_txt_5 = input.color(color.white, "4H Yazı Rengi", group="Tablo 4H Ayarları")
t_note_6 = input.string("GÜN", "GÜN Notu", group="Tablo GÜN Ayarları"), t_bg_6 = input.color(color.new(color.orange, 0), "GÜN Arka Plan", group="Tablo GÜN Ayarları"), t_txt_6 = input.color(color.white, "GÜN Yazı Rengi", group="Tablo GÜN Ayarları")
t_note_7 = input.string("HFT", "HFT Notu", group="Tablo HFT Ayarları"), t_bg_7 = input.color(color.new(color.orange, 0), "HFT Arka Plan", group="Tablo HFT Ayarları"), t_txt_7 = input.color(color.white, "HFT Yazı Rengi", group="Tablo HFT Ayarları")

// --- 2. TEKNİK HESAPLAMALAR ---
ap = hlc3 
esa = ta.ema(ap, n1), d = ta.ema(math.abs(ap - esa), n1)
ci = (ap - esa) / (0.015 * d), tci = ta.ema(ci, n2)
wt1 = tci, wt2 = ta.sma(wt1, 4)
[macdLine, signalLine, _] = ta.macd(close, fast_length, slow_length, signal_smoothing)

sma5=ta.sma(close, 5), sma8=ta.sma(close, 8), sma13=ta.sma(close, 13), sma21=ta.sma(close, 21), sma34=ta.sma(close, 34), sma55=ta.sma(close, 55), sma89=ta.sma(close, 89), sma144=ta.sma(close, 144)
smaTrend = (sma5 + sma8 + sma13 + sma21 + sma34) / 5
trendColor = close > smaTrend ? color.new(color.lime, 5) : color.new(color.red, 5)

high_pivot = ta.pivothigh(high, pp_period, pp_period)
low_pivot  = ta.pivotlow(low, pp_period, pp_period)

var float last_resistance = na
var float tp1_val = na, var float tp2_val = na, var float tp3_val = na
var float[] res_history = array.new_float(0)

if not na(high_pivot)
    last_resistance := high_pivot
    array.push(res_history, high_pivot)
    if array.size(res_history) > 30 
        array.remove(res_history, 0)

if barstate.islast
    float[] sorted_res = array.copy(res_history)
    array.sort(sorted_res, order.ascending)
    int found = 0
    float last_added_val = close 
    for i = 0 to array.size(sorted_res) - 1
        r = array.get(sorted_res, i)
        if r > (last_added_val * tp_min_dist)
            if found == 0
                tp1_val := r
                last_added_val := r
            else if found == 1
                tp2_val := r
                last_added_val := r
            else if found == 2
                tp3_val := r
                last_added_val := r
            found += 1

// --- 3. SİNYAL MANTIĞI ---
wt_cross_up   = ta.crossover(wt1, wt2) and wt1 < osLevel
macd_cross_up = ta.crossover(macdLine, signalLine)
s_trend_buy   = ta.crossover(close, smaTrend)
bool s_breakout_buy = ta.crossover(close, last_resistance) and close > last_resistance

bool s_wt_active    = wt_cross_up or (ta.barssince(wt_cross_up) <= 10 and not ta.crossunder(wt1, wt2))
bool s_macd_active  = macd_cross_up or (ta.barssince(macd_cross_up) <= 10)
bool s_trend_active = s_trend_buy

color combo_color = color.lime
string combo_emoji = "🔥", string combo_details = ""
int al_sayac = 0

if s_wt_active
    al_sayac += 1
    combo_details += "WT "
if s_macd_active
    al_sayac += 1
    combo_details += "MACD "
if s_trend_active
    al_sayac += 1
    combo_details += "TRND "
if s_breakout_buy
    al_sayac += 1
    combo_details += "KIRILIM"

if s_wt_active and s_trend_active and not s_macd_active
    combo_color := color.yellow 
else if s_macd_active and s_trend_active and not s_wt_active
    combo_color := color.green  
else if s_wt_active and s_macd_active
    combo_color := color.blue   

bool s_kombo_buy = al_sayac >= 2
cross55 = ta.crossover(smaTrend, sma55), cross89 = ta.crossover(smaTrend, sma89)
since55 = ta.barssince(cross55)
bool s_strong_buy = cross89 and since55 > 0 and since55 <= 6
bool s_cross_buy  = ta.crossover(smaTrend, sma55) 
bool s_cross34_buy = ta.crossover(smaTrend, sma34) 

var bool wt_sell_ready = false
if ta.crossunder(wt1, wt2) and wt1 > obLevel
    wt_sell_ready := true

bool s_wt_sell = false
if wt_sell_ready and ta.crossunder(close, sma34)
    s_wt_sell := true
    wt_sell_ready := false

if s_strong_buy or s_kombo_buy
    wt_sell_ready := false

// --- 4. GRAFİK ÜSTÜ ÇİZİMLER ---
float arrow_pos = low * (1 - (arrow_dist_input / 100)), float sell_arrow_pos = high * (1 + (arrow_dist_input / 100))
float text_pos  = arrow_pos * (1 - (text_dist_input / 100)), float sell_text_pos = sell_arrow_pos * (1 + (text_dist_input / 100))

plotshape(s_strong_buy ? arrow_pos : na, "Mega Al Ok", shape.triangleup, location.absolute, #00ffea, size=size.tiny)
if s_strong_buy
    label.new(bar_index, text_pos, "🚀\n GÜÇLÜ\n AL\n 89", xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_up, #00ffea, size.small)

plotshape(s_kombo_buy and not s_strong_buy ? arrow_pos : na, "Kombo Al Ok", shape.triangleup, location.absolute, combo_color, size=size.tiny)
if s_kombo_buy and not s_strong_buy
    label.new(bar_index, text_pos, combo_emoji + " \n(" + combo_details + ")", xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_up, combo_color, size.small)

plotshape(s_breakout_buy and not s_kombo_buy and not s_strong_buy ? arrow_pos : na, "Kırılım Ok", shape.triangleup, location.absolute, color.rgb(241, 2, 241), size=size.tiny)
if s_breakout_buy and not s_kombo_buy and not s_strong_buy
    label.new(bar_index, text_pos, "💎\n DİRENÇ", xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_up, color.rgb(241, 2, 241), size.small)

var label l_tp1 = na, var line n_tp1 = na
var label l_tp2 = na, var line n_tp2 = na
var label l_tp3 = na, var line n_tp3 = na

if show_labels and barstate.islast
    if not na(tp1_val)
        label.delete(l_tp1), line.delete(n_tp1)
        n_tp1 := line.new(bar_index - 30, tp1_val, bar_index + 10, tp1_val, color=color.new(color.blue, 30), width=1, style=line.style_dashed)
        l_tp1 := label.new(bar_index + 10, tp1_val, "🎯 HEDEF 1: " + str.tostring(tp1_val, "#.##"), color=color.new(color.blue, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)
    if not na(tp2_val)
        label.delete(l_tp2), line.delete(n_tp2)
        n_tp2 := line.new(bar_index - 30, tp2_val, bar_index + 10, tp2_val, color=color.new(color.orange, 30), width=1, style=line.style_dashed)
        l_tp2 := label.new(bar_index + 10, tp2_val, "🎯 HEDEF 2: " + str.tostring(tp2_val, "#.##"), color=color.new(color.orange, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)
    if not na(tp3_val)
        label.delete(l_tp3), line.delete(n_tp3)
        n_tp3 := line.new(bar_index - 30, tp3_val, bar_index + 10, tp3_val, color=color.new(color.red, 30), width=1, style=line.style_dashed)
        l_tp3 := label.new(bar_index + 10, tp3_val, "🎯 HEDEF 3: " + str.tostring(tp3_val, "#.##"), color=color.new(color.red, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

plotshape(s_cross_buy and not s_kombo_buy and not s_strong_buy and not s_breakout_buy ? arrow_pos : na, "Kesişim Ok 55", shape.triangleup, location.absolute, color.white, size=size.tiny)
if s_cross_buy and not s_kombo_buy and not s_strong_buy and not s_breakout_buy
    label.new(bar_index, text_pos, "SMA\n 55", xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_up, color.white, size.small)

plotshape(s_cross34_buy and not s_cross_buy and not s_kombo_buy and not s_strong_buy and not s_breakout_buy ? arrow_pos : na, "Kesişim Ok 34", shape.triangleup, location.absolute, color.yellow, size=size.tiny)
if s_cross34_buy and not s_cross_buy and not s_kombo_buy and not s_strong_buy and not s_breakout_buy
    label.new(bar_index, text_pos, "SMA\n 34", xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_up, color.yellow, size.small)

plotshape(s_wt_sell ? sell_arrow_pos : na, "Sat Ok", shape.triangledown, location.absolute, color.yellow, size=size.tiny)
if s_wt_sell
    label.new(bar_index, sell_text_pos, "SAT", xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_down, color.yellow, size.small)

plot(smaTrend, "ÖMER Trend", color=trendColor, linewidth=3)
plot(sma34, "SMA 34", color=color.yellow, linewidth=2) 
plot(sma55, "SMA 55", color=color.white, linewidth=2)
plot(sma89, "SMA 89", color=color.aqua, linewidth=2) 
plot(sma144, "SMA 144", color=color.purple, linewidth=2)

// --- 5. DESTEK VE DİRENÇ ---
var line r_line = na, var line s_line = na, var label r_lab = na, var label s_lab = na
if not na(high_pivot)
    line.delete(r_line), label.delete(r_lab)
    r_line := line.new(bar_index[pp_period], high_pivot, bar_index, high_pivot, color=color.new(#ff00ea, 0), width=2, extend=extend.right)
    if show_labels
        r_lab := label.new(bar_index + 5, high_pivot, "Direnç: " + str.tostring(high_pivot, "#.##"), style=label.style_label_left, textcolor=color.white, color=color.rgb(241, 2, 241), size=size.small)

if not na(low_pivot)
    line.delete(s_line), label.delete(s_lab)
    s_line := line.new(bar_index[pp_period], low_pivot, bar_index, low_pivot, color=color.new(color.lime, 20), width=2, extend=extend.right)
    if show_labels
        s_lab := label.new(bar_index + 5, low_pivot, "Destek: " + str.tostring(low_pivot, "#.##"), style=label.style_label_left, textcolor=color.white, color=color.green, size=size.tiny)

// --- 6. FIBONACCI ---
float hH = ta.highest(high, fibo_lookback), lL =ta.lowest(low, fibo_lookback)
if barstate.islast
    lvls = array.from(0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0)
    clrs = array.from(color.white, color.blue, color.red, color.orange, color.yellow, color.purple, color.white)
    for i = 0 to 6
        v = lL + ((hH - lL) * array.get(lvls, i))
        line.new(bar_index[fibo_lookback], v, bar_index + 10, v, color=array.get(clrs, i), style=line.style_dashed)
        label.new(bar_index + 10, v, str.tostring(array.get(lvls, i)*100, "#.#") + "% (" + str.tostring(v, "#.##") + ")", style=label.style_none, textcolor=array.get(clrs, i), size=size.small)

// --- 7. MTF TABLO ---
f_get_mtf() =>
    [_s, _d] = ta.supertrend(3.0, 10), _e = ta.ema(close, 21), _sma144_mtf = ta.sma(close, 144)
    [ml, sl, _] = ta.macd(close, 12, 26, 9), _hp = ta.pivothigh(high, 20, 20)
    var float _last_r = na
    if not na(_hp)
        _last_r := _hp
    _is_break = ta.crossover(close, _last_r)
    _break_txt = _is_break ? "KIRILDI" : (close > _last_r ? "ÜST✅" : "ALT🔻")
    _since_break = ta.barssince(_is_break)
    _durum = _d < 0 ? (close > _e ? "GÇL AL" : "AL") : (close < _e ? "GÇL SAT" : "SAT")
    _dCol  = _d < 0 ? color.new(color.green, close > _e ? 0 : 40) : color.new(color.red, close < _e ? 0 : 40)
    _mSig = ta.barssince(ta.crossover(ml, sl)) <= 3 ? "KESİŞİM ↑" : ta.barssince(ta.crossunder(ml, sl)) <= 3 ? "KESİŞİM ↓" : "-"
    _fP = (close - ta.lowest(low, 200)) / math.max(1, ta.highest(high, 200) - ta.lowest(low, 200))
    _144Durum = close > _sma144_mtf ? "ÜST" : "ALT", _144Renk = close > _sma144_mtf ? color.green : color.red
    [_durum, _break_txt, _since_break, _fP, _mSig, _dCol, _144Durum, _144Renk]

[d5, bT5, bS5, f5, m5, c5, s144_5, col144_5] = request.security(syminfo.tickerid, "5", f_get_mtf())
[d15, bT15, bS15, f15, m15, c15, s144_15, col144_15] = request.security(syminfo.tickerid, "15", f_get_mtf())
[d60, bT60, bS60, f60, m60, c60, s144_60, col144_60] = request.security(syminfo.tickerid, "60", f_get_mtf())
[d120, bT120, bS120, f120, m120, c120, s144_120, col144_120] = request.security(syminfo.tickerid, "120", f_get_mtf())
[d240, bT240, bS240, f240, m240, c240, s144_240, col144_240] = request.security(syminfo.tickerid, "240", f_get_mtf())
[dD, bTD, bSD, fD, mD, cD, s144_D, col144_D] = request.security(syminfo.tickerid, "D", f_get_mtf())
[dW, bTW, bSW, fW, mW, cW, s144_W, col144_W] = request.security(syminfo.tickerid, "W", f_get_mtf())

var table panel = table.new(position.bottom_center, 7, 6, border_width=1)
f_fill_p(_col, _per, _dur, _breakT, _breakS, _fp, _ms, _dc, _s144, _c144, _customNote, _bgColor, _txtColor) =>
    table.cell(panel, _col, 0, _customNote, bgcolor=_bgColor, text_color=_txtColor, text_size=size.tiny)
    table.cell(panel, _col, 1, _per + "\nF%" + str.tostring(_fp * 100, "#.#"), bgcolor=#3e29f8, text_color=color.white, text_size=size.tiny)
    table.cell(panel, _col, 2, _dur, bgcolor=_dc, text_color=color.white, text_size=size.tiny)
    table.cell(panel, _col, 3, _breakT + "\nM:" + str.tostring(_breakS), bgcolor=color.black, text_color=(_breakT=="KIRILDI"?color.lime:color.white), text_size=size.tiny)
    table.cell(panel, _col, 4, _ms, bgcolor=(_ms=="KESİŞİM ↑"?color.teal:_ms=="KESİŞİM ↓"?color.maroon:color.black), text_color=color.white, text_size=size.tiny)
    table.cell(panel, _col, 5, "144:" + _s144, bgcolor=color.black, text_color=_c144, text_size=size.tiny)

if barstate.islast
    f_fill_p(0, "5M", d5, bT5, bS5, f5, m5, c5, s144_5, col144_5, t_note_1, t_bg_1, t_txt_1)
    f_fill_p(1, "15M", d15, bT15, bS15, f15, m15, c15, s144_15, col144_15, t_note_2, t_bg_2, t_txt_2)
    f_fill_p(2, "1H", d60, bT60, bS60, f60, m60, c60, s144_60, col144_60, t_note_3, t_bg_3, t_txt_3)
    f_fill_p(3, "2H", d120, bT120, bS120, f120, m120, c120, s144_120, col144_120, t_note_4, t_bg_4, t_txt_4)
    f_fill_p(4, "4H", d240, bT240, bS240, f240, m240, c240, s144_240, col144_240, t_note_5, t_bg_5, t_txt_5)
    f_fill_p(5, "GÜN", dD, bTD, bSD, fD, mD, cD, s144_D, col144_D, t_note_6, t_bg_6, t_txt_6)
    f_fill_p(6, "HFT", dW, bTW, bSW, fW, mW, cW, s144_W, col144_W, t_note_7, t_bg_7, t_txt_7)

// --- 8. YENİ ÖZELLİK: GELİŞMİŞ DİNAMİK MUM KANALI ---
var float ch_high  = na, var float ch_low   = na, var int   ch_start = na
var float last_upper_high = na, var float last_upper_low  = na
var float last_lower_high = na, var float last_lower_low  = na
var box ch_box = na, var label ch_info = na
var box next_high_box = na, var box next_low_box = na
var label pred_u_top_lab = na, var label pred_u_bot_lab = na
var label pred_l_top_lab = na, var label pred_l_bot_lab = na

if show_candle_channel 
    if na(ch_high) or na(ch_low)
        ch_high := high[1], ch_low := low[1], ch_start := bar_index - 1
    
    if high > ch_high 
        last_lower_high := ch_high, last_lower_low := ch_low
        ch_high := high[1], ch_low := low[1], ch_start := bar_index - 1
    else if low < ch_low
        last_upper_high := ch_high, last_upper_low := ch_low
        ch_high := high[1], ch_low := low[1], ch_start := bar_index - 1

    if barstate.islast
        float channel_range = ch_high - ch_low, int pred_length = 15 
        box.delete(ch_box), label.delete(ch_info)
        ch_box := box.new(ch_start, ch_high, bar_index + 5, ch_low, bgcolor=channel_color, border_color=channel_border_color, border_style=line.style_dashed)
        ch_info := label.new(ch_start, ch_high, "AKTİF KANAL", color=color.new(color.black, 100), textcolor=channel_border_color, style=label.style_label_down, size=size.small)

        box.delete(next_high_box), box.delete(next_low_box)
        label.delete(pred_u_top_lab), label.delete(pred_u_bot_lab)
        label.delete(pred_l_top_lab), label.delete(pred_l_bot_lab)

        // Üst Öngörü Kutusu ve Yazıları
        float u_bot = ch_high 
        float u_top = not na(last_upper_high) and last_upper_high > ch_high ? last_upper_high : ch_high + channel_range
        next_high_box := box.new(bar_index, u_top, bar_index + pred_length, u_bot, bgcolor=upper_pred_color, border_color=upper_pred_color, border_style=line.style_dotted)
        
        // ETİKETLERİ KUTUNUN ÜSTÜNE/DIŞINA ALDIK (style_label_down ve style_label_up kullanarak)
        pred_u_top_lab := label.new(bar_index + 10, u_top, "Üst Öngörü Tavan: " + str.tostring(u_top, "#.##"), color=color.new(color.black, 100), textcolor=upper_txt_color, style=label.style_label_down, size=size.tiny)
        pred_u_bot_lab := label.new(bar_index + 10, u_bot, "Üst Öngörü Taban: " + str.tostring(u_bot, "#.##"), color=color.new(color.black, 100), textcolor=upper_txt_color, style=label.style_label_up, size=size.tiny)

        // Alt Öngörü Kutusu ve Yazıları
        float l_top = ch_low
        float l_bot = not na(last_lower_low) and last_lower_low < ch_low ? last_lower_low : ch_low - channel_range
        next_low_box := box.new(bar_index, l_top, bar_index + pred_length, l_bot, bgcolor=lower_pred_color, border_color=lower_pred_color, border_style=line.style_dotted)

        // ETİKETLERİ KUTUNUN ALTINA/DIŞINA ALDIK
        pred_l_top_lab := label.new(bar_index + 10, l_top, "Alt Öngörü Tavan: " + str.tostring(l_top, "#.##"), color=color.new(color.black, 100), textcolor=lower_txt_color, style=label.style_label_down, size=size.tiny)
        pred_l_bot_lab := label.new(bar_index + 10, l_bot, "Alt Öngörü Taban: " + str.tostring(l_bot, "#.##"), color=color.new(color.black, 100), textcolor=lower_txt_color, style=label.style_label_up, size=size.tiny)

// --- 9. HİSSE LİSTELERİ VE RADAR ---
