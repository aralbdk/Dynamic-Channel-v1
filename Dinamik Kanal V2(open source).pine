    t

f_radar_logic(look) =>
    int k_idx = -1, int s_idx = -1, int c_idx = -1, int c34_idx = -1, int b_idx = -1
    string k_emoji = ""
    float score = 0.0
    for i = 0 to look
        if s_strong_buy[i] and s_idx == -1
            s_idx := i
            score += 500 
        if s_kombo_buy[i] and k_idx == -1
            k_idx := i
            score += 250
            if s_wt_active[i] and s_trend_active[i] and not s_macd_active[i]
                k_emoji := "🟡"
            else if s_macd_active[i] and s_trend_active[i] and not s_wt_active[i]
                k_emoji := "🟢"
            else if s_wt_active[i] and s_macd_active[i]
                k_emoji := "🔵"
            else
                k_emoji := "🔥"
        if s_breakout_buy[i] and b_idx == -1
            b_idx := i
            score += 150
        if s_cross_buy[i] and c_idx == -1
            c_idx := i
            score += 100
        if s_cross34_buy[i] and c34_idx == -1
            c34_idx := i
            score += 80
    _fP = (close - ta.lowest(low, 200)) / math.max(1, ta.highest(high, 200) - ta.lowest(low, 200))
    [k_idx, s_idx, c_idx, c34_idx, b_idx, _fP, score, k_emoji]

f_pad(_t) =>
    _s = _t
    if str.length(_t) < 6
        for i = 1 to (6 - str.length(_t))
            _s += " "
    _s

if barstate.islast
    var string radarTxt = "🚀 TARAMA LİSTESİ 🚀\n"
    var tickerLines = array.new_string(0)
    var tickerScores = array.new_float(0)
    for i = 1 to 35
        sym = f_get_t(groupInput, i)
        if sym != ""
            [k, s, c, c34, b, fP, sc, k_emo] = request.security("BIST:" + sym, timeframe.period, f_radar_logic(radar_lookback), ignore_invalid_symbol=true)
            if (s != -1 or k != -1 or c != -1 or c34 != -1 or b != -1) and fP < 0.98
                string lineTxt = "🔸 " + f_pad(sym) + ": "
                if s != -1
                    lineTxt += "🚀(" + str.tostring(s) + ") "
                if k != -1
                    lineTxt += k_emo + "(" + str.tostring(k) + ") "
                if b != -1
                    lineTxt += "💎(" + str.tostring(b) + ") "
                if c != -1
                    lineTxt += "⚪(" + str.tostring(c) + ") "
                if c34 != -1
                    lineTxt += "⚪34(" + str.tostring(c34) + ") "
                array.push(tickerLines, lineTxt)
                array.push(tickerScores, sc)
    
    if array.size(tickerScores) > 1
        for i = 0 to array.size(tickerScores) - 2
            for j = i + 1 to array.size(tickerScores) - 1
                if array.get(tickerScores, i) < array.get(tickerScores, j)
                    tempS = array.get(tickerScores, i)
                    array.set(tickerScores, i, array.get(tickerScores, j))
                    array.set(tickerScores, j, tempS)
                    tempL = array.get(tickerLines, i)
                    array.set(tickerLines, i, array.get(tickerLines, j))
                    array.set(tickerLines, j, tempL)
    
    string finalContent = ""
    if array.size(tickerLines) > 0
        for i = 0 to array.size(tickerLines) - 1
            finalContent += array.get(tickerLines, i) + "\n"
    else
        finalContent := "Güçlü Sinyal Yok..."
    
    label.new(bar_index + offset_x, close, radarTxt + finalContent, color=color.new(#001aff, 47), textcolor=color.white, style=label.style_label_left, size=size.normal, text_font_family=font.family_monospace)
